FROM python:3.11-slim
WORKDIR /app

# Install deps
COPY requirements.txt .
RUN pip install -r requirements.txt

# Copy your code
COPY . .

# Create a startup script (start.sh)
RUN echo '#!/bin/bash\n\
adk api_server --with_ui --port=8000 --host=0.0.0.0 --session_service_uri=memory:// & \
streamlit run app.py --server.port=8080 --server.address=0.0.0.0' > start.sh
RUN chmod +x start.sh

EXPOSE 8080 8000

# Run the startup script
CMD ["./start.sh"]